<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Para Alguien Especial</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #ffeef2;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }

        .container {
            text-align: center;
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            max-width: 90%;
            width: 350px;
            transition: all 0.5s ease;
        }

        h2 { color: #ff4a70; margin-bottom: 20px; }
        
        input[type="date"] {
            padding: 10px;
            border: 2px solid #ffb3c1;
            border-radius: 10px;
            font-size: 16px;
            outline: none;
            width: 80%;
            margin-bottom: 20px;
        }

        button {
            background-color: #ff4a70;
            color: white;
            border: none;
            padding: 12px 25px;
            font-size: 16px;
            border-radius: 25px;
            cursor: pointer;
            transition: background 0.3s;
        }

        button:hover { background-color: #e0385f; }

        .error-msg { color: #d9381e; font-size: 14px; margin-top: 10px; display: none; }

        /* Pantalla de las Flores */
        #flower-stage { display: none; }

        /* Animación básica de la flor (Capullo a Florecer) */
        .flower-box {
            position: relative;
            width: 100px;
            height: 150px;
            margin: 0 auto 20px auto;
            cursor: pointer;
        }

        .stem {
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 6px;
            height: 90px;
            background-color: #4caf50;
            transform: translateX(-50%);
            border-radius: 3px;
        }

        .bud {
            position: absolute;
            top: 25px;
            left: 50%;
            width: 40px;
            height: 40px;
            background-color: #8cbb8e; /* Color verde capullo inicial */
            border-radius: 50% 50% 0 0;
            transform: translateX(-50%);
            transition: all 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* Cuando florece */
        .flower-box.bloom .bud {
            background-color: #ff0033; /* Rojo intenso */
            width: 80px;
            height: 80px;
            top: 0;
            border-radius: 50%;
            box-shadow: 0 0 15px rgba(255, 0, 51, 0.5);
        }

        #message {
            font-size: 24px;
            font-weight: bold;
            color: #ff0033;
            opacity: 0;
            transform: scale(0.5);
            transition: all 1s ease 1s; /* Espera a que la flor abra */
        }

        .flower-box.bloom + #message {
            opacity: 1;
            transform: scale(1);
        }
        
        .hint { font-size: 12px; color: #aaa; margin-top: 5px;}
    </style>
</head>
<body>

    <div id="auth-stage" class="container">
        <h2>¿Cuándo es tu cumple? ¡Introduce la fecha!</h2>
        <input type="date" id="birthdate">
        <br>
        <button onclick="checkDate()">Ingresar</button>
        <p id="error" class="error-msg">¡Upps! Esa no es la fecha correcta. Inténtalo de nuevo. ❤️</p>
    </div>

    <div id="flower-stage" class="container">
        <h2 id="instruction">¡Toca el capullo para que florezca!</h2>
        
        <div class="flower-box" onclick="bloomFlower(this)">
            <div class="stem"></div>
            <div class="bud"></div>
        </div>

        <div id="message">feliz cumpleaños <3</div>
    </div>

    <script>
        function checkDate() {
            const inputDate = document.getElementById('birthdate').value;
            if (!inputDate) return;

            // Extraemos mes y día (YYYY-MM-DD)
            const parts = inputDate.split('-');
            const month = parts[1];
            const day = parts[2];

            // Validamos que sea el 10 de Junio (10-06)
            if (day === '10' && month === '06') {
                document.getElementById('auth-stage').style.display = 'none';
                document.getElementById('flower-stage').style.display = 'block';
            } else {
                document.getElementById('error').style.display = 'block';
            }
        }

        function bloomFlower(element) {
            element.classList.add('bloom');
            document.getElementById('instruction').style.opacity = '0';
        }
    </script>
</body>
</html>
